<?xml version="1.0" encoding="utf-8"?>
<!-- A frying pan cooking: a side-on skillet (curved bowl + handle) with steam
     rising off it. Filled + stroked paths; the Icon tint recolours the whole
     drawable, so both the pan and the steam pick up the cook-mode accent. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Pan bowl: a shallow curved trough, flat rim on top. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M3,13.5 C3,17.6 15,17.6 15,13.5 Z" />
    <!-- Handle: a bar angling up to the right off the pan's rim. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M14.4,12.6 L21.3,9.5 L22,11.1 L15.1,14.2 Z" />
    <!-- Two wisps of steam rising from the pan. -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M7,11 c-1.3,-1.4 1.3,-2.6 0,-4 c-1.3,-1.4 1.3,-2.6 0,-4" />
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M11,11 c-1.3,-1.4 1.3,-2.6 0,-4 c-1.3,-1.4 1.3,-2.6 0,-4" />
</vector>
