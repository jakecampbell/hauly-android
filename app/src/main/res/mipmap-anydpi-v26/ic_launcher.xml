<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <!--
      The bag artwork sits right at the adaptive-icon safe zone, so aggressive
      launcher masks clip its top and bottom. Inset the foreground 8% to pull the
      bag comfortably inside the safe zone. The foreground is full-bleed #06AFFF,
      identical to the background color, so the inset border blends seamlessly.
    -->
    <foreground>
        <inset
            android:drawable="@mipmap/ic_launcher_foreground"
            android:inset="8%" />
    </foreground>
</adaptive-icon>
